# Copy this file to .env before running locally: cp .env.example .env

HTTP_PORT=8080
DB_DSN=postgres://notifier:notifier@localhost:5432/notifications?sslmode=disable
RMQ_URL=amqp://guest:guest@localhost:5672/
WEBHOOK_URL=https://webhook.site/21932283-4eb3-4b39-95d1-33f471adfab7
WEBHOOK_TIMEOUT=10s
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=30s

# ── E2E test overrides ──────────────────────────────────────────────────────
# TEST_DB_DSN is auto-derived by make test-e2e (swaps "notifications" →
# "notifications_test" in DB_DSN). Override here only if your setup differs.
# TEST_DB_DSN=postgres://notifier:notifier@localhost:5432/notifications_test?sslmode=disable
#
# TEST_RMQ_URL defaults to RMQ_URL. Override only if e2e tests use a
# dedicated vhost or separate broker.
# TEST_RMQ_URL=amqp://guest:guest@localhost:5672/
